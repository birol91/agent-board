{
  "name": "agentdeck",
  "version": "0.0.0",
  "private": true,
  "description": "Visual control panel for Claude Code agents, skills, memory, and configuration.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @agentdeck/desktop",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "postinstall": "node scripts/install.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}
